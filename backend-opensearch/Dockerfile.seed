FROM golang:1.25-alpine AS builder

WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 go build -o /seed ./cmd/seed

FROM alpine:3.21
RUN addgroup -S app && adduser -S -G app app \
    && apk --no-cache add ca-certificates tzdata
COPY --from=builder /seed /seed
USER app
CMD ["/seed"]
